{
  "name": "uneri",
  "version": "0.0.1",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sksat/orts",
    "directory": "uneri"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./style.css": "./dist/index.css",
    "./align": "./src/utils/alignTimeSeries.ts"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build && tsc --emitDeclarationOnly",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "example:sine-wave": "npx tsx examples/sine-wave/server.ts & npx vite --config vite.example.config.ts --port 5174",
    "example:mixed-density": "npx tsx examples/mixed-density/server.ts & npx vite --config vite.mixed-density.config.ts --port 5175"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "dependencies": {
    "@duckdb/duckdb-wasm": "1.33.1-dev20.0",
    "uplot": "^1.6.32"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/react": "^19.2.13",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.0",
    "happy-dom": "^20.5.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vite": "^8.0.0",
    "vite-plugin-dts": "^4.0.0",
    "vitest": "^4.0.18",
    "ws": "^8.18.0"
  }
}
