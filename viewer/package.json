{
  "name": "orts-viewer",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sksat/orts",
    "directory": "viewer"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build:wasm": "wasm-pack build ../kaname --target web --out-dir ../viewer/src/wasm/kaname --out-name kaname -- --features wasm",
    "build": "pnpm run build:wasm && tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@duckdb/duckdb-wasm": "1.33.1-dev18.0",
    "uneri": "workspace:*",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "three": "^0.170.0",
    "uplot": "^1.6.32"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/react": "^19.2.13",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.170.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.1.3",
    "happy-dom": "^20.5.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^4.0.18",
    "ws": "^8.19.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
