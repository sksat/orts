{
  "name": "orts-viewer",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sksat/orts",
    "directory": "viewer"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build:wasm:arika": "wasm-pack build ../arika --target web --out-dir ../viewer/src/wasm/arika --out-name arika -- --locked --features wasm",
    "build:wasm:rrd": "wasm-pack build ../rrd-wasm --target web --out-dir ../viewer/src/wasm/rrd-wasm --out-name rrd_wasm -- --locked --features wasm",
    "build:wasm": "pnpm run build:wasm:arika && pnpm run build:wasm:rrd",
    "build": "pnpm run build:wasm && tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@duckdb/duckdb-wasm": "1.32.0",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "three": "^0.183.0",
    "@sksat/uneri": "workspace:*",
    "uplot": "^1.6.32"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/react": "^19.2.13",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.183.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.0",
    "happy-dom": "^20.5.0",
    "rollup-plugin-license": "^3.7.1",
    "typescript": "^5.7.0",
    "vite": "^8.0.8",
    "vitest": "^4.1.4",
    "ws": "^8.19.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
