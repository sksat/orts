/target
plugin-sdk/examples/target/
node_modules/
dist/
test-results/
.playwright-mcp/

# Prevent debug screenshots from accumulating in repo root
/*.png
/*.jpeg

# High-resolution textures (downloaded via tools/fetch-textures.sh)
viewer/public/textures/*_4k.*
viewer/public/textures/*_8k.*

# arika WASM build artifacts (wasm-pack generates .gitignore; .d.ts is force-tracked)
viewer/src/wasm/arika/*.js
viewer/src/wasm/arika/*.wasm
viewer/src/wasm/arika/package.json

# rrd-wasm WASM build artifacts (.d.ts is force-tracked)
viewer/src/wasm/rrd-wasm/*.js
viewer/src/wasm/rrd-wasm/*.wasm
viewer/src/wasm/rrd-wasm/package.json

# Orekit data cache (downloaded by tools/generate_hp_fixtures.py)
orekit-data.zip
orekit-data/

# Environment variables (credentials)
.env

# Embedded viewer assets (copied by cli/build.rs from viewer/)
cli/viewer-dist/
cli/textures/

# Embedded assets in docs (copied by docs/scripts/embed-viewer.mjs)
docs/public/viewer/
docs/public/uneri/examples/
docs/public/tobari/

# tobari-example-web WASM build artifacts (.d.ts is force-tracked)
tobari/examples/web/src/wasm/tobari/*.js
tobari/examples/web/src/wasm/tobari/*.wasm
tobari/examples/web/src/wasm/tobari/package.json
tobari/examples/web/src/wasm/arika/*.js
tobari/examples/web/src/wasm/arika/*.wasm
tobari/examples/web/src/wasm/arika/package.json

# Downloaded space weather data (fetched by embed-viewer.mjs)
tobari/examples/web/public/space-weather.txt

# TypeDoc generated API docs (regenerated by starlight-typedoc during astro build)
docs/src/content/docs/en/uneri/api/

# Python virtual environments
.venv/

# Generated HTML files (PyVista/Plotly exports)
apollo11_3d*.html

# Claude Code local settings (not shared)
.claude/settings.local.json
