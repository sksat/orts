{
  "name": "orts-docs",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "setup": "node scripts/embed-viewer.mjs",
    "dev": "ALLOW_MISSING_VIEWER_DIST=1 ALLOW_MISSING_TOBARI=1 STARLIGHT_RUSTDOC_SKIP=1 pnpm run setup && astro dev",
    "prebuild": "pnpm run setup",
    "build": "astro build",
    "preview": "astro preview",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@astrojs/react": "^5.0.0",
    "@astrojs/starlight": "^0.38.1",
    "astro": "^6.0.5",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "starlight-rustdoc": "workspace:*",
    "starlight-typedoc": "^0.21.5",
    "typedoc": "^0.28.17",
    "typedoc-plugin-markdown": "^4.10.0",
    "uneri": "workspace:*"
  },
  "devDependencies": {
    "vitest": "^4.1.4"
  }
}
